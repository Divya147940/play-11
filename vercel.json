{
  "version": 2,
  "public": true,
  "outputDirectory": "frontend/dist",
  "functions": {
    "backend/index.js": {
      "runtime": "vercel-node@latest"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
